# Local developer setup:
# 1. Set GOOGLE_TRANSLATE_API_KEY
# 2. Leave TRANSLATE_SHARED_SECRET blank
# 3. Leave GOOGLE_ACCESS_TOKEN blank
# 4. Run ./script/run_backend.sh from the repo root
#
# Only use GOOGLE_CLOUD_PROJECT and the endpoint/location settings below
# if you intentionally want the advanced service-account flow instead of
# the simple API-key flow.

PORT=8080
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_TRANSLATE_ENDPOINT=translate-eu.googleapis.com
GOOGLE_TRANSLATE_LOCATION=europe-west1
GOOGLE_TRANSLATE_MODEL=general/nmt
GOOGLE_TRANSLATE_BASIC_ENDPOINT=translation.googleapis.com
GOOGLE_TRANSLATE_LABELS_JSON={"app":"circle2search","surface":"screen_translate"}
APP_STORE_EXPECTED_BUNDLE_ID=com.circle2search.app
APP_STORE_RECEIPT_CACHE_TTL_SECONDS=21600
TRANSLATE_RATE_LIMIT_WINDOW_SECONDS=60
TRANSLATE_RATE_LIMIT_MAX_REQUESTS=30
TRANSLATE_ALLOW_LOCALHOST_WITHOUT_AUTH=true
TRANSLATE_SHARED_SECRET=
GOOGLE_ACCESS_TOKEN=
